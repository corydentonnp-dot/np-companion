# NP Companion — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git — it is excluded by .gitignore.
#
# config.py reads these values at startup. Any setting defined in .env
# overrides the default in config.py.

# ============================================================
# SERVER SETTINGS
# ============================================================
FLASK_SECRET_KEY=generate-a-random-32-char-string-here
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ============================================================
# AMAZING CHARTS (EHR)
# ============================================================
AC_LOGIN_USERNAME=your-ac-username
AC_LOGIN_PASSWORD=your-ac-password
AC_MOCK_MODE=False
AC_EXE_PATH=C:\Program Files (x86)\Amazing Charts\AmazingCharts.exe
AC_DB_PATH=\\192.168.2.51\Amazing Charts\AmazingCharts.mdf
AC_IMPORTED_ITEMS_PATH=\\192.168.2.51\amazing charts\ImportItems
AC_PRACTICE_ID=2799

# ============================================================
# NETPRACTICE / WEBPRACTICE
# ============================================================
NETPRACTICE_URL=https://wppm2.cgmus.com/scripts/npm7.mar
NETPRACTICE_CLIENT_NUMBER=2034
CHROME_CDP_PORT=9222

# ============================================================
# NOTIFICATIONS (Pushover)
# ============================================================
PUSHOVER_USER_KEY=your-pushover-user-key
PUSHOVER_API_TOKEN=your-pushover-api-token

# ============================================================
# MACHINE-SPECIFIC PATHS
# ============================================================
TESSERACT_PATH=C:\Users\FPA\AppData\Local\Programs\Tesseract-OCR\tesseract.exe
DATABASE_PATH=data/npcompanion.db

# ============================================================
# EXTERNAL API KEYS (for Phase 10 intelligence features)
# ============================================================
# These are free-tier or open APIs unless noted otherwise.

# Anthropic (Claude AI assistant features)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# LOINC (requires free registration at loinc.org)
LOINC_USERNAME=your-loinc-username
LOINC_PASSWORD=your-loinc-password

# UMLS (requires free UMLS license at uts.nlm.nih.gov)
UMLS_API_KEY=your-umls-api-key

# NCBI / PubMed (free, optional — increases rate limit)
NCBI_API_KEY=your-ncbi-api-key

# OpenFDA (free, optional — increases rate limit)
OPENFDA_API_KEY=your-openfda-api-key

# CMS Physician Fee Schedule locality
CMS_LOCALITY_NUMBER=your-virginia-locality-number
CMS_CONVERSION_FACTOR=33.40
