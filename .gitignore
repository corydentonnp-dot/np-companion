# CareCompanion ignore rules
# File location in project: carecompanion/.gitignore (project root, alongside app.py and config.py)
# config.py is excluded because it contains sensitive machine-specific credentials and secrets

# Runtime data -- selective exclusions
# SQLite databases are binary and cause unsolvable merge conflicts -- always exclude
data/*.db
data/*.sqlite
# Machine-specific runtime state
data/active_user.json
data/active_chart.json
# Noisy / large output directories
data/logs/
data/backups/
data/clinical_summaries/
# Log files inside data/
data/server.log
data/server_test.log
data/test_results.txt
# JSON reference files (help_guide, rems_database, etc.) ARE tracked -- they sync between computers

# Python cache and compiled files
__pycache__/
*.pyc
*.pyo

# Virtual environments
venv/
.venv/

# VS Code workspace settings (exclude most, but allow shared settings)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/mcp.json

# Session cookies / serialized data
*.pkl

# Log files (top-level and nested)
*.log

# Generated output
deploy_check_output.txt

# Build output
dist/
build/
*.ico

# Environment file
.env

# Workspace
*.code-workspace
data/active_chart.json
